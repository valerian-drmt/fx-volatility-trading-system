.venv/
# Tooling caches — each also self-gitignores via an internal .gitignore,
# but list them at root for belt + suspenders + discoverability.
.pytest_cache/
.mypy_cache/
.ruff_cache/
.import_linter_cache/
__pycache__/
*.py[cod]
*.egg-info/
src/*.egg-info/
CLAUDE.md
.claude
.idea
.env
.env.local
releases
# frontend
frontend/node_modules/
frontend/dist/
frontend/coverage/
frontend/.vite/
frontend/*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts
frontend/playwright-report/
frontend/test-results/

# IB Gateway local build — installer binaries are licensed (no redistribute)
# and the upstream/ clone is a third-party repo maintained separately.
infrastructure/ib-gateway/upstream/
market-data.log
*.log

# Operator scratch dumps from live debug sessions (position P&L snapshots etc.)
pin.json
