        <mxCell id="indices-note" value="📌 INDICES (migration 002)&#xa;• ix_positions_status_symbol  (covering for Vol Scanner WHERE status=OPEN)&#xa;• ix_position_snapshots_position_id_timestamp  (composite, for timeline queries)&#xa;• ix_trades_position_id_timestamp&#xa;• ix_account_snaps_timestamp DESC&#xa;• ix_vol_surfaces_underlying_timestamp DESC  +  GIN (surface_data jsonb_path_ops)&#xa;• ix_signals_timestamp DESC, ix_signals_underlying_tenor_timestamp&#xa;• ix_svi_params_underlying_tenor_timestamp DESC&#xa;• ix_ssvi_params_underlying_timestamp DESC&#xa;• ix_backtest_runs_strategy_name_created_at DESC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;fontSize=11" parent="1" vertex="1">
          <mxGeometry x="40" y="1170" width="900" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cycles-note" value="🔄 WRITE CYCLES&lt;br&gt;&lt;br&gt;MarketDataEngine — toutes les 100ms (ticks)&lt;br&gt;  → tick stream (Redis cache, pas Postgres)&lt;br&gt;  → account_snaps (toutes les 60s)&lt;br&gt;&lt;br&gt;VolEngine — toutes les ~180s (vol scan complet)&lt;br&gt;  → vol_surfaces (1 row par scan)&lt;br&gt;  → signals (1 row par tenor par scan, ~6-8 tenors EURUSD)&lt;br&gt;  → svi_params (1 row par tenor par scan)&lt;br&gt;  → ssvi_params (1 row par scan)&lt;br&gt;&lt;br&gt;RiskEngine — toutes les ~60s&lt;br&gt;  → position_snapshots (1 row par position OPEN)&lt;br&gt;&lt;br&gt;OrderExecutor — sur événement&lt;br&gt;  → positions (INSERT à open + UPDATE à close)&lt;br&gt;  → trades (INSERT par fill IB)&lt;br&gt;&lt;br&gt;FastAPI /admin/config (PUT) — sur action user&lt;br&gt;  → vol_config (INSERT new version, append-only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=center;verticalAlign=top;fontSize=11" parent="1" vertex="1">
          <mxGeometry x="990" y="900" width="610" height="440" as="geometry" />
        </mxCell>
      </root>
