        <mxCell id="title" value="IBClient Tick Data: Send / Receive Paths" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="30" y="20" width="520" height="40" as="geometry" />
        </mxCell>
        <mxCell id="problem_note" value="Problem / confusion: tick data is available via multiple patterns&#xa;1) event queue (_on_ticker_update -&gt; _received_ticks)&#xa;2) latest snapshot read (get_latest_bid_ask)&#xa;3) one-shot snapshot API (get_market_snapshot / request_market_data snapshot=True)" style="shape=note;whiteSpace=wrap;html=1;size=16;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="30" y="70" width="620" height="150" as="geometry" />
        </mxCell>
        <mxCell id="external_ib" value="IB Gateway / TWS&#xa;(market data source)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="590" y="270" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m_connect" value="IBClient.connect_and_prepare(ticker)&#xa;reqMktData(Forex(ticker))&#xa;_attach_ticker_listener()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="880" y="50" width="360" height="100" as="geometry" />
        </mxCell>
        <mxCell id="m_onupdate" value="IBClient._on_ticker_update(...)&#xa;RECEIVE event updateEvent&#xa;append tick dict to _received_ticks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="1500" y="50" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="queue" value="IBClient._received_ticks (queue)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1870" y="65" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p_get_ticks" value="PipelineRunner.get_ib_ticks()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="1090" y="180" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m_process" value="IBClient.process_messages()&#xa;SEND request: ib.sleep(0)&#xa;RECEIVE processed events&#xa;return drain_received_ticks()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="1420" y="245" width="280" height="90" as="geometry" />
