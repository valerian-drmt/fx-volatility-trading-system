# Copy to .env and fill in local values. Never commit .env.

# PostgreSQL (R1) — used by SQLAlchemy async engine and Alembic
# Port 5433 on the host to avoid conflict with a native Postgres on 5432.
# The container still listens on 5432 internally (see docker-compose.dev.yml).
DATABASE_URL=postgresql+asyncpg://fxvol:fxvol@localhost:5433/fxvol
DB_PASSWORD=fxvol

# Redis (R3) — live-state cache + pub/sub bus.
# Port 6380 on the host for the same reason as Postgres : avoid clashing
# with a native Redis on 6379. The container listens on 6379 internally.
REDIS_URL=redis://localhost:6380/0

# --- Production-like compose (R6) ---

# VNC password for the IB Gateway container (PR #4). Kept in .env so the
# prod compose never ships a default ; Docker Compose will refuse to start
# if the variable is missing (`${VAR:?message}` syntax in docker-compose.yml).
VNC_PASSWORD=change-me

# IB Gateway paper-trading credentials (PR #4). Leave blank in dev — the
# ib-gateway service will stay in "login required" state until filled.
IB_USERID=
IB_PASSWORD=
